---
interface Props {
  title: string;
  href: string;
  date: Date;
  description?: string;
  tags?: string[];
  minutes?: number;
}
const { title, href, date, description, tags = [], minutes } = Astro.props;
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<li>
  <a class="title-link" href={href}>
    <div class="post-row">
      <time datetime={date.toISOString()}>{dateStr}</time>
      <div>
        <div class="title">{title}</div>
        {description && <div class="desc">{description}</div>}
        {tags.length > 0 && (
          <div class="tags">
            {tags.map((t) => <span>{t}</span>)}
          </div>
        )}
      </div>
      {minutes && <span class="read">{minutes} min</span>}
    </div>
  </a>
</li>
