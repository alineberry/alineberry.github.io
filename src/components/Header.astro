---
const path = Astro.url.pathname;
// Normalize for exact match — trailingSlash is 'always'
const norm = path.endsWith('/') ? path : path + '/';
const isOn = (p: string) => (norm === p ? 'page' : undefined);
---

<header class="site">
  <div class="wrap topbar">
    <a class="brand" href="/" aria-label="Adam Lineberry, home">
      <span class="mark" aria-hidden="true">AL</span>
      <span class="wordmark-long">Adam Lineberry</span>
    </a>
    <nav class="primary" aria-label="Primary">
      <a href="/" aria-current={isOn('/')}>Writing</a>
      <a href="/notes/" aria-current={isOn('/notes/')}>Notes</a>
      <a href="/about/" aria-current={isOn('/about/')}>About</a>
    </nav>
  </div>
</header>
