---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  minutes?: number;
  isNote?: boolean;
}
const { title, description, date, tags = [], minutes, isNote = false } = Astro.props;
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const kicker = isNote ? 'Note' : 'Essay';
---

<BaseLayout
  title={`${title} — Adam Lineberry`}
  description={description}
  ogType="article"
  publishedTime={date}
  tags={tags}
>
  <article class="post">
    <div class="wrap wrap--narrow">
      <header class="post-head">
        <div class="post-kicker">
          <span>{kicker}</span>
          <span class="line"></span>
          <time datetime={date.toISOString()}>{dateStr}</time>
        </div>
        <h1>{title}</h1>
        <div class="post-meta">
          {minutes && <span>{minutes} min read</span>}
          {tags.length > 0 && minutes && <span class="sep">·</span>}
          {tags.map((t) => <span class="chip">#{t.replace(/\s+/g, '-')}</span>)}
        </div>
      </header>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
