---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Adam Lineberry" description="About Adam Lineberry.">
  <section class="wrap wrap--narrow">
    <div class="about-card">
      <img class="avatar" src="/images/headshot2.jpeg" alt="Adam Lineberry" width="160" height="160" />
      <div>
        <h1>Adam Lineberry</h1>
        <div class="role">Machine Learning Engineer · South Carolina</div>
        <p>
          I'm a Machine Learning Engineer at Kensho Technologies, S&amp;P Global's AI
          lab. My work spans agentic engineering, harness engineering, and building a
          powerful, AI-friendly data layer that exposes S&amp;P data — specifically
          end-to-end ingestion and agentic retrieval of unstructured document content.
        </p>
        <p>
          I started working in machine learning in 2017 after spending the first few
          years of my career working as a structural engineer designing large industrial
          steel and concrete structures. I still hold a Professional Engineer license.
        </p>
        <p>
          This blog is where I write about ideas that interest me, both to strengthen
          my own understanding and to share with others.
        </p>
        <div class="socials">
          <a href="https://www.linkedin.com/in/adam-lineberry/">LinkedIn</a>
          <a href="https://github.com/alineberry">GitHub</a>
          <a href="https://twitter.com/adamlineberryML">X</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
