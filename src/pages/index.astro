---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostListItem from '../components/PostListItem.astro';
import { getEssays, readingTime, postHref } from '../lib/posts';

const essays = await getEssays();
const count = essays.length;
const latestYear = essays[0]?.data.date.getFullYear() ?? new Date().getFullYear();
---

<BaseLayout title="Adam Lineberry">
  <section class="hero">
    <div class="wrap">
      <div class="eyebrow">ML Engineer · Denver, CO</div>
      <h1>
        Notes on machine learning, <span class="grad">written to understand them better</span>.
      </h1>
      <p class="lede">
        I'm an ML engineer at Kensho, S&amp;P Global's AI lab — working on agentic
        systems, harness engineering, and the data layer behind both. This is where I
        write things down — derivations, experiments, and the occasional tangent — to
        make sure I actually understand them.
      </p>
      <div class="meta">
        <span class="pip"></span>
        <span>{count} essays · last updated {latestYear}</span>
      </div>
    </div>
  </section>

  <section class="feed">
    <div class="wrap">
      <h2>Recent writing</h2>
      <ul class="posts">
        {essays.map((p) => (
          <PostListItem
            title={p.data.title}
            href={postHref(p)}
            date={p.data.date}
            description={p.data.description}
            tags={p.data.tags}
            minutes={readingTime(p.body ?? '')}
          />
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
